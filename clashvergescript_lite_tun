  },
  "ai_domain": {
    "type": "http",
    "format": "mrs",
    "interval": 86400,
    "behavior": "domain",
    "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/category-ai-!cn.mrs",
    "path": "./ruleset/simonwei999/ai_domain.mrs"
  }    
};

// 规则顺序
const rules = [
  "RULE-SET,private_ip,全局直连,no-resolve",
  "RULE-SET,private_domain,全局直连",
  "RULE-SET,ai_domain,AI",
  "RULE-SET,direct1,全局直连", 
  "RULE-SET,proxy1,默认代理",
  "RULE-SET,cn_domain,全局直连",  
  "RULE-SET,cn_ip,全局直连",  
  "RULE-SET,geolocation-!cn,默认代理",
  "MATCH,漏网之鱼"
];
// 代理组通用配置
const groupBaseOption = {
  "interval": 300,
  "timeout": 3000,
  "url": "https://www.google.com/generate_204",
  "lazy": true,
  "max-failed-times": 3
};

function main(config) {
  // 注入新配置
  config["dns"] = dnsConfig;
  config["rule-providers"] = ruleProviders;
  config["rules"] = rules;

  // 代理组配置
  config["proxy-groups"] = [
    {
      ...groupBaseOption,
      "name": "节点选择",
      "type": "select",
      "include-all": true
    },
    {
      ...groupBaseOption,
      "name": "全局直连",
      "type": "select",
      "proxies": ["DIRECT"]
    },
    {
      ...groupBaseOption,
      "name": "香港-自动",
      "type": "url-test",
      "include-all": true,
      "filter": "(?i)香港|HK|Hong Kong"
    },
    {
      ...groupBaseOption,
      "name": "美国-自动",
      "type": "url-test",
      "include-all": true,
      "filter": "(?i)美国|US|United States"
    },
    {
      ...groupBaseOption,
      "name": "默认代理",
      "type": "select",
      "proxies": ["节点选择", "香港-自动", "美国-自动", "全局直连"]
    },
    {
      ...groupBaseOption,
      "name": "AI",
      "type": "select",
      "proxies": ["美国-自动", "香港-自动", "台湾-自动", "日本-自动", "新加坡-自动", "韩国-自动", "节点选择"],
      "icon": "https://fastly.jsdelivr.net/gh/clash-verge-rev/clash-verge-rev.github.io@main/docs/assets/icons/apple.svg"
    },
    {
      ...groupBaseOption,
      "name": "漏网之鱼",
      "type": "select",
      "proxies": ["默认代理", "全局直连"]
    }
  ];

  // 确保所有节点开启 UDP 转发
  if (config["proxies"]) {
    config["proxies"].forEach(p => p.udp = true);
  }

  return config;
}
